# Shared internal-service credential. Use the same value for auth, org,
# lowcode, and workflow-engine in local development.
INTERNAL_SERVICE_TOKEN=triobase-local-internal-token

# Workflow-engine local endpoints.
WF_DB_URL=jdbc:postgresql://localhost:5433/triobase
WF_DB_USERNAME=triobase
WF_DB_PASSWORD=triobase123
AUTH_SERVICE_URL=http://localhost:8081
ORG_SERVICE_URL=http://localhost:8082
LOWCODE_SERVICE_URL=http://localhost:8085
WF_SERVICE_URL=http://localhost:8086

# Temporal is exposed by docker/docker-compose.yml.
TEMPORAL_TARGET=127.0.0.1:7233
