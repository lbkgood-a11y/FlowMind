FROM maven:3.9.11-eclipse-temurin-21 AS build
WORKDIR /workspace
COPY . .
RUN mvn -pl trio-base-services/service-openapi -am -DskipTests package

FROM eclipse-temurin:21-jre
RUN useradd --system --uid 10001 triobase
WORKDIR /app
COPY --from=build /workspace/trio-base-services/service-openapi/target/service-openapi-*.jar app.jar
USER triobase
EXPOSE 8088
ENTRYPOINT ["java", "-XX:MaxRAMPercentage=75", "-jar", "/app/app.jar"]
